%% ╔═══════════════════════════════════════════════════════════════════════╗
%% ║  DIAGRAM B — RELAY LIFECYCLE (ON-DEMAND START / STOP)                ║
%% ╚═══════════════════════════════════════════════════════════════════════╝

flowchart TD
    BrowserStart([Browser sends<br/>action: start_relay<br/>relay_id: 1]) --> LockMtx[Lock RelayManager mutex]
    LockMtx --> AlreadyActive{Relay already<br/>active?}
    AlreadyActive -->|Yes| NoOp([No-op: already running])
    AlreadyActive -->|No| FindConfig{Find relay config<br/>by ID}
    FindConfig -->|Not found| ErrUnknown([Error: unknown relay])
    FindConfig -->|Found| CreatePipeline[Create RelayPipeline<br/>config + db + ws + shmRing]

    CreatePipeline --> StartPipeline[pipeline.start]

    subgraph PipelineStart[Pipeline Startup]
        direction TB
        P1[Create PipelineReceptionWorker<br/>with ConnectionFSM + CommandFSM]
        P1 --> P2[rxWorker.start<br/>spawn worker thread]
        P2 --> P3[Fire start_event<br/>FSM: Idle → Connecting]
        P3 --> P4[Create PipelineProcessingWorker]
        P4 --> P5[procWorker.start<br/>register ring reader + spawn thread]
        P5 --> P6[Queue initial SER command]
    end

    StartPipeline --> PipelineStart
    PipelineStart --> StoreActive[Store in active map]
    StoreActive --> RelayRunning([Relay Running<br/>Polling + Processing])

    %% Stop path
    BrowserStop([Browser sends<br/>action: stop_relay<br/>relay_id: 1]) --> LockMtx2[Lock RelayManager mutex]
    LockMtx2 --> FindActive{Relay in<br/>active map?}
    FindActive -->|No| ErrNotActive([Error: not active])
    FindActive -->|Yes| StopPipeline[pipeline.stop]

    subgraph PipelineStop[Pipeline Shutdown]
        direction TB
        X1[rxWorker.stop<br/>set stop_flag + notify CV]
        X1 --> X2[Join reception thread]
        X2 --> X3[procWorker.stop<br/>set stop_flag + notifyAll ring]
        X3 --> X4[Join processing thread]
    end

    StopPipeline --> PipelineStop
    PipelineStop --> EraseActive[Erase from active map]
    EraseActive --> RelayStopped([Relay Stopped])

    %% Status query
    BrowserStatus([Browser sends<br/>action: relay_status]) --> GetIds[Get active relay IDs]
    GetIds --> ReturnStatus([Return JSON<br/>active: 1, 3])

    style BrowserStart fill:#e3f2fd,stroke:#1565c0
    style BrowserStop fill:#fff3e0,stroke:#ef6c00
    style BrowserStatus fill:#f3e5f5,stroke:#7b1fa2
    style RelayRunning fill:#e8f5e9,stroke:#2e7d32
    style RelayStopped fill:#eceff1,stroke:#546e7a
    style NoOp fill:#eceff1,stroke:#546e7a
    style ErrUnknown fill:#ffebee,stroke:#c62828
    style ErrNotActive fill:#ffebee,stroke:#c62828


%% ═══════════════════════════════════════════════════════════════════════════


%% ╔═══════════════════════════════════════════════════════════════════════╗
%% ║  DIAGRAM C — SER POLL CYCLE (FULL DATA PIPELINE)                     ║
%% ╚═══════════════════════════════════════════════════════════════════════╝

flowchart TD
    %% Trigger
    Timer([SERPoller Timer<br/>every 120 seconds]) --> GetActive[Get active relay IDs<br/>from RelayManager]
    GetActive --> AnyActive{Any relays<br/>active?}
    AnyActive -->|No| SkipPoll([Skip — no active relays])
    AnyActive -->|Yes| QueueLoop[For each active relay:<br/>queueCommand SER]

    %% Thread 1 — Reception
    QueueLoop --> Dequeue[ReceptionWorker dequeues<br/>SER from command_queue]
    Dequeue --> DriveOp[driveToOperational<br/>step ConnectionFSM]
    DriveOp --> IsOp{FSM state =<br/>Operational?}
    IsOp -->|Error| CmdFail[Command Failed]
    IsOp -->|Yes| FireCmd[fireCommandEvent<br/>SER via CommandFSM]

    FireCmd --> SendCmd[TelnetClient<br/>SendCmdReceiveData<br/>SER → Relay TCP:23]
    SendCmd --> CmdOK{Response<br/>received?}
    CmdOK -->|Fail| Disconnect[process disconnect_event<br/>FSM → Connecting]
    Disconnect --> Retry{Retries<br/>< 3?}
    Retry -->|Yes| DriveOp
    Retry -->|No| CmdFail
    CmdOK -->|OK| PushRing[Push to RawDataRingBuffer<br/>cmd: SER, response: data]

    CmdFail --> LogErr([Log error — skip this cycle])

    %% Thread 2 — Processing
    PushRing --> WaitPop[ProcessingWorker<br/>waitPop — blocking]
    WaitPop --> IsSER{Command<br/>= SER?}
    IsSER -->|No| BroadcastText[wsServer.broadcastText<br/>raw response to browser]
    BroadcastText --> Done([Done — continue loop])

    IsSER -->|Yes| Parse[parseSERResponse<br/>text → vector of SERRecord]
    Parse --> HasRecords{Records<br/>parsed?}
    HasRecords -->|No| LogNoRec([Log: no records — continue])
    HasRecords -->|Yes| StampRelay[Stamp relay_id + relay_name<br/>on every record]

    StampRelay --> Step1

    subgraph Step1[Step 1 — Database]
        direction TB
        DB1[db.insertAndGetNewRecords]
        DB1 --> DB2[BEGIN TRANSACTION]
        DB2 --> DB3[INSERT OR IGNORE each record]
        DB3 --> DB4[COMMIT]
        DB4 --> DB5[Return newRecords + inserted count]
    end

    Step1 --> Step2

    subgraph Step2[Step 2 — WebSocket Broadcast]
        direction TB
        WS1[wsServer.broadcastAll]
        WS1 --> WS2[db.getAllRecords]
        WS2 --> WS3[encodeSerRecordsToTlv<br/>ASN.1 BER/TLV binary]
        WS3 --> WS4[Send to all connected<br/>browser sessions]
    end

    Step2 --> NewData{inserted<br/>> 0?}
    NewData -->|No| Done2([Done — continue loop])
    NewData -->|Yes| Step3

    subgraph Step3[Step 3 — Shared Memory]
        direction TB
        SHM1[encodeSerRecordsToTlv<br/>new records only]
        SHM1 --> SHM2[shmRing.write<br/>TLV payload]
    end

    Step3 --> Done2

    %% Thread 5 — JSON Writer
    SHM2 -.->|IPC ring buffer| T5Start[SharedSerReader<br/>waitRead — blocking]
    T5Start --> Decode[decodeSerRecordsFromTlv]
    Decode --> DecodeOK{Decode<br/>OK?}
    DecodeOK -->|Error| LogDec([Log error — skip])
    DecodeOK -->|OK| ToJSON[recordsToJsonTable<br/>split timestamp → date + time]
    ToJSON --> WriteFile[writeJsonToFile<br/>ui/data.json]
    WriteFile --> WriteOK{Write<br/>OK?}
    WriteOK -->|Error| LogWrite([Log error — continue])
    WriteOK -->|OK| FileReady([ui/data.json updated<br/>for Tabulator])

    style Timer fill:#fff3e0,stroke:#ef6c00
    style SkipPoll fill:#eceff1,stroke:#546e7a
    style CmdFail fill:#ffebee,stroke:#c62828
    style LogErr fill:#ffebee,stroke:#c62828
    style Done fill:#e8f5e9,stroke:#2e7d32
    style Done2 fill:#e8f5e9,stroke:#2e7d32
    style FileReady fill:#e8f5e9,stroke:#2e7d32
    style Step1 fill:#e8f5e9,stroke:#2e7d32
    style Step2 fill:#e3f2fd,stroke:#1565c0
    style Step3 fill:#fff3e0,stroke:#ef6c00


%% ═══════════════════════════════════════════════════════════════════════════


%% ╔═══════════════════════════════════════════════════════════════════════╗
%% ║  DIAGRAM D — BROWSER REQUEST DISPATCH (WEBSOCKET ON_READ)            ║
%% ╚═══════════════════════════════════════════════════════════════════════╝

flowchart TD
    Msg([WebSocket message<br/>received from browser]) --> Closed{Connection<br/>closed / error?}
    Closed -->|Yes| Deregister[Deregister from<br/>SessionManager]
    Deregister --> End1([Session ended])

    Closed -->|No| ParseMsg[Parse message string]
    ParseMsg --> IsRefresh{msg = refresh<br/>or getData?}

    IsRefresh -->|Yes| SendData[sendData<br/>query all DB records<br/>encode ASN.1 TLV<br/>send binary frame]
    SendData --> DoRead1([do_read — wait next])

    IsRefresh -->|No| IsJSON{Is JSON action?<br/>starts with curly brace<br/>and has action key}

    IsJSON -->|Yes| ExtractAction[Extract action value]
    ExtractAction --> MaskPwd{action =<br/>change_password?}
    MaskPwd -->|Yes| MaskLog[Mask payload in log]
    MaskPwd -->|No| FullLog[Log full message]
    MaskLog --> SpawnAction
    FullLog --> SpawnAction

    SpawnAction[Spawn detached thread] --> RouteAction

    subgraph RouteAction[Action Dispatch]
        direction TB
        A1{action?}
        A1 -->|start_relay| StartRelay[RelayManager<br/>startRelay relay_id]
        A1 -->|stop_relay| StopRelay[RelayManager<br/>stopRelay relay_id]
        A1 -->|relay_status| RelayStatus[Return active IDs]
        A1 -->|read_time| ReadTime[TimeSyncManager<br/>handleReadTime]
        A1 -->|sync_time| SyncTime[TimeSyncManager<br/>handleSyncTime]
        A1 -->|change_password| ChgPwd[PasswordManager<br/>handleAction]
    end

    RouteAction --> PostBack[Post JSON response<br/>back to WS strand]
    PostBack --> DoRead2([do_read — wait next])

    IsJSON -->|No| HasHandler{Has stream or<br/>cmd handler?}
    HasHandler -->|No| IgnoreMsg([Ignore — do_read])

    HasHandler -->|Yes| ParsePrefix[Parse relay_id:command<br/>prefix format]
    ParsePrefix --> SpawnCmd[Spawn detached thread]

    SpawnCmd --> TryStream{StreamCommandHandler<br/>available?}
    TryStream -->|Yes| IsFetchAll{Command =<br/>FETCH_ALL_TAR?}

    IsFetchAll -->|Yes| StreamLoop

    subgraph StreamLoop[FETCH_ALL_TAR Streaming]
        direction TB
        SL1[Loop: TAR 0, TAR 1, ...]
        SL1 --> SL2[handleUserCommand<br/>relay_id, TAR i]
        SL2 --> SL3{Response empty<br/>or Invalid Target?}
        SL3 -->|Yes| SL4[Send TAR_STREAM_END:count]
        SL3 -->|No| SL5[Send TAR_STREAM:i + response]
        SL5 --> SL6{abort flag?}
        SL6 -->|No| SL1
        SL6 -->|Yes| SL4
    end

    StreamLoop --> DoRead3([do_read — wait next])

    IsFetchAll -->|No| FallThrough[Not handled as stream]
    TryStream -->|No| FallThrough

    FallThrough --> SingleCmd[cmdHandler<br/>handleUserCommand<br/>synchronous response]
    SingleCmd --> HasResp{Response<br/>non-empty?}
    HasResp -->|Yes| SendText[sendTextResponse<br/>text WS frame]
    HasResp -->|No| SkipSend[Skip empty response]
    SendText --> DoRead4([do_read — wait next])
    SkipSend --> DoRead4

    style Msg fill:#e3f2fd,stroke:#1565c0
    style End1 fill:#eceff1,stroke:#546e7a
    style IgnoreMsg fill:#eceff1,stroke:#546e7a
    style DoRead1 fill:#e8f5e9,stroke:#2e7d32
    style DoRead2 fill:#e8f5e9,stroke:#2e7d32
    style DoRead3 fill:#e8f5e9,stroke:#2e7d32
    style DoRead4 fill:#e8f5e9,stroke:#2e7d32
    style RouteAction fill:#f3e5f5,stroke:#7b1fa2
    style StreamLoop fill:#fff3e0,stroke:#ef6c00


