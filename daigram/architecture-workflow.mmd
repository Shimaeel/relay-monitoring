%% ╔═══════════════════════════════════════════════════════════════════════╗
%% ║  DIAGRAM J — BROWSER → RELAY COMMAND PATHS (UI INITIATED)           ║
%% ╚═══════════════════════════════════════════════════════════════════════╝
%%
%%  All paths a browser action can take to reach a physical relay
%%  and return a response to the UI.
%%
%% ═══════════════════════════════════════════════════════════════════════════

flowchart TD
    subgraph BrowserActions["Browser UI — User Actions"]
      direction TB
      ClickSER["Click: Refresh SER"]
      ClickTAR["Click: Fetch TAR Reports"]
      ClickCmd["Type: FIL DIR / EVE / SET"]
      ClickTime["Click: Read Time / Sync Time"]
      ClickPwd["Click: Change Password"]
      ClickStart["Click: Start Relay"]
      ClickStop["Click: Stop Relay"]
      ClickCTR["Click: COMTRADE Download"]
    end

    subgraph WSTransport["WebSocket :8765"]
      direction TB
      RefreshMsg["send: refresh"]
      StreamMsg["send: relay_id:FETCH_ALL_TAR"]
      CmdMsg["send: relay_id:FIL DIR"]
      ActionTime["send: JSON action read_time"]
      ActionPwd["send: JSON action change_password"]
      ActionStart["send: JSON action start_relay"]
      ActionStop["send: JSON action stop_relay"]
      CmdCTR["send: relay_id:CTR C/D n"]
    end

    subgraph BackendRoute["C++ Backend Routing"]
      direction TB
      SendData["sendData<br/>DB → TLV → binary frame"]
      StreamHandler["StreamCommandHandler<br/>loop TAR 0..N<br/>stream each response"]
      CmdHandler["CommandHandler<br/>handleUserCommand<br/>sync mutex path"]
      TimeSyncH["TimeSyncManager<br/>DATE / SETTIME → relay"]
      PwdH["PasswordManager<br/>PAS LEVEL1/2 → relay"]
      StartH["RelayManager.startRelay<br/>create pipeline + threads"]
      StopH["RelayManager.stopRelay<br/>destroy pipeline"]
      CtrH["CommandHandler<br/>CTR C/D n → relay"]
    end

    subgraph RelayIO["Relay I/O"]
      direction TB
      TelSER["TelnetClient→ SER"]
      TelTAR["TelnetClient→ TAR n"]
      TelCmd["TelnetClient→ FIL DIR"]
      TelDate["TelnetClient→ DATE / SETTIME"]
      TelPas["TelnetClient→ PAS LEVEL1"]
      TelCtr["TelnetClient→ CTR C/D n"]
      RelayDev["Relay Device<br/>TCP:23"]
    end

    subgraph Response["Response to Browser"]
      direction TB
      BinResp["Binary: ASN.1 TLV<br/>→ Tabulator table"]
      TextStream["Text: TAR_STREAM:i<br/>→ per-target display"]
      TextResp["Text: raw relay output<br/>→ pre/code display"]
      JSONResp["JSON: relay_time, pc_time<br/>→ time comparison UI"]
      JSONPwd["JSON: ok/error<br/>→ status message"]
      JSONStartStop["JSON: active relay list<br/>→ dashboard cards"]
      TextCtr["Text: COMTRADE data<br/>→ file download"]
    end

    %% Browser → WS
    ClickSER --> RefreshMsg
    ClickTAR --> StreamMsg
    ClickCmd --> CmdMsg
    ClickTime --> ActionTime
    ClickPwd --> ActionPwd
    ClickStart --> ActionStart
    ClickStop --> ActionStop
    ClickCTR --> CmdCTR

    %% WS → Backend
    RefreshMsg --> SendData
    StreamMsg --> StreamHandler
    CmdMsg --> CmdHandler
    ActionTime --> TimeSyncH
    ActionPwd --> PwdH
    ActionStart --> StartH
    ActionStop --> StopH
    CmdCTR --> CtrH

    %% Backend → Relay
    StreamHandler --> TelTAR
    CmdHandler --> TelCmd
    TimeSyncH --> TelDate
    PwdH --> TelPas
    CtrH --> TelCtr
    TelTAR --> RelayDev
    TelCmd --> RelayDev
    TelDate --> RelayDev
    TelPas --> RelayDev
    TelCtr --> RelayDev

    %% SendData does not go to relay (reads DB directly)
    SendData --> BinResp

    %% Response paths
    RelayDev -->|"TAR text"| TextStream
    RelayDev -->|"cmd output"| TextResp
    RelayDev -->|"date string"| JSONResp
    RelayDev -->|"ACK / error"| JSONPwd
    RelayDev -->|"COMTRADE"| TextCtr
    StartH --> JSONStartStop
    StopH --> JSONStartStop

    style BrowserActions fill:#e8f5e9,stroke:#2e7d32
    style WSTransport fill:#eceff1,stroke:#546e7a
    style BackendRoute fill:#e3f2fd,stroke:#1565c0
    style RelayIO fill:#fce4ec,stroke:#e91e63
    style Response fill:#f3e5f5,stroke:#7b1fa2
