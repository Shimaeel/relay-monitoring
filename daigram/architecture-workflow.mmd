%% ╔═══════════════════════════════════════════════════════════════════════╗
%% ║  DIAGRAM E — CONNECTION FSM & COMMAND FSM                            ║
%% ╚═══════════════════════════════════════════════════════════════════════╝

stateDiagram-v2
    direction LR

    state "RelayConnectionFSM" as ConnFSM {
        [*] --> Idle
        Idle --> Connecting : start_event

        Connecting --> Login_L1 : ConnectOk
        Connecting --> ConnectWait : ConnectFail

        ConnectWait --> Connecting : step\n(sleep 1s chunks)
        note right of ConnectWait : Unlimited retries\nChecks stop_flag

        Login_L1 --> Operational : Login1Complete
        Login_L1 --> LoginRetryWait : CanRetry\n(retries < 3)
        Login_L1 --> ConnectWait : Login1Fail\n(not InvalidCred)
        Login_L1 --> Error : MaxRetries = 3

        LoginRetryWait --> Connecting : step\n(sleep 1s chunks)

        Operational --> Operational : step\n(self-loop, ready)
        Operational --> Connecting : disconnect_event\n(reconnect cycle)

        Error --> [*]
    }

    state "RelayCommandFSM" as CmdFSM {
        [*] --> CmdIdle
        CmdIdle --> CmdSerAction : cmd_ser_event\n(SER)
        CmdIdle --> CmdTarAction : cmd_tar_event\n(TAR args)
        CmdIdle --> CmdEveAction : cmd_eve_event\n(EVE)
        CmdIdle --> CmdCtrlCAction : cmd_ctrlc_event\n(Ctrl+C)
        CmdIdle --> CmdCtrlDAction : cmd_ctrld_event\n(Ctrl+D)
        CmdIdle --> CmdSetAction : cmd_set_event\n(SET args)

        CmdSerAction --> CmdIdle : done
        CmdTarAction --> CmdIdle : done
        CmdEveAction --> CmdIdle : done
        CmdCtrlCAction --> CmdIdle : done
        CmdCtrlDAction --> CmdIdle : done
        CmdSetAction --> CmdIdle : done

        note right of CmdIdle : Unknown commands bypass FSM\nvia generic SendCmdReceiveData
    }


%% ═══════════════════════════════════════════════════════════════════════════


%% ╔═══════════════════════════════════════════════════════════════════════╗
%% ║  DIAGRAM F — COMMAND EXECUTION (ASYNC QUEUE vs SYNC USER)            ║
%% ╚═══════════════════════════════════════════════════════════════════════╝

flowchart TD
    subgraph AsyncPath[Async Path — Poll / Queued Commands]
        direction TB
        AP1([SERPoller or queueCommand]) --> AP2[Push to command_queue]
        AP2 --> AP3[queue_cv.notify_one]
        AP3 --> AP4[Worker thread dequeues]
        AP4 --> AP5[executeCommand<br/>up to 3 retries]
        AP5 --> AP6[driveToOperational<br/>step ConnectionFSM]
        AP6 --> AP7{Operational?}
        AP7 -->|Error| AP8([Log failure])
        AP7 -->|Yes| AP9[fireCommandEvent<br/>via CommandFSM]
        AP9 --> AP10{Success?}
        AP10 -->|Yes| AP11[rawBuffer.push<br/>cmd + response]
        AP10 -->|No| AP12[disconnect_event<br/>FSM → Connecting]
        AP12 --> AP13{Retry < 3?}
        AP13 -->|Yes| AP6
        AP13 -->|No| AP8
    end

    subgraph SyncPath[Sync Path — Browser User Commands]
        direction TB
        SP1([Browser click<br/>relay_id:FIL DIR]) --> SP2[Acquire sync_cmd_mutex]
        SP2 --> SP3[handleUserCommand<br/>up to 3 retries]
        SP3 --> SP4[driveToOperational<br/>step ConnectionFSM]
        SP4 --> SP5{Operational?}
        SP5 -->|Error| SP6([Return error string])
        SP5 -->|Yes| SP7[fireCommandEvent<br/>via CommandFSM]
        SP7 --> SP8{Success?}
        SP8 -->|Yes| SP9([Return response text<br/>directly to browser])
        SP8 -->|No| SP10[disconnect_event<br/>FSM → Connecting]
        SP10 --> SP11{Retry < 3?}
        SP11 -->|Yes| SP4
        SP11 -->|No| SP6
    end

    Note1[Both paths share the same<br/>TelnetClient and FSM instances<br/>sync_cmd_mutex prevents races]

    style AsyncPath fill:#e3f2fd,stroke:#1565c0
    style SyncPath fill:#fff3e0,stroke:#ef6c00
    style Note1 fill:#f5f5f5,stroke:#9e9e9e


%% ═══════════════════════════════════════════════════════════════════════════


%% ╔═══════════════════════════════════════════════════════════════════════╗
%% ║  DIAGRAM G — WSDB SERVER (PORT 8766) REQUEST DISPATCH                ║
%% ╚═══════════════════════════════════════════════════════════════════════╝

flowchart TD
    DBReq([Browser sends JSON<br/>to ws://localhost:8766]) --> ParseJSON[Parse JSON:<br/>id, action, table, sql, params]

    ParseJSON --> Route{action?}

    Route -->|getAll| GetAll[dbGetAll<br/>SELECT rowid, * FROM table]
    Route -->|getIncremental| GetInc[dbGetIncremental<br/>WHERE rowid > sinceRowId]
    Route -->|query| Query[dbQuery<br/>arbitrary SELECT + bind params]
    Route -->|exec| Exec[dbExec<br/>INSERT / UPDATE / DELETE / DDL]
    Route -->|tables| Tables[dbTables<br/>sqlite_master query]
    Route -->|schema| Schema[dbSchema<br/>PRAGMA table_info]
    Route -->|define| Define[dbDefine<br/>CREATE TABLE from JSON columns]
    Route -->|unknown| ErrAction([Error: unknown action])

    GetAll --> SendResp[Send JSON response]
    GetInc --> SendResp
    Query --> SendResp
    Tables --> SendResp
    Schema --> SendResp

    Exec --> NotifyShm{SharedDBMemory<br/>configured?}
    Define --> NotifyShm

    NotifyShm -->|No| SendResp
    NotifyShm -->|Yes| PubChange[Publish change notification<br/>to shared memory block]
    PubChange --> SendResp

    SendResp --> ReadNext([do_read — wait next request])

    style DBReq fill:#e3f2fd,stroke:#1565c0
    style ErrAction fill:#ffebee,stroke:#c62828
    style ReadNext fill:#e8f5e9,stroke:#2e7d32
    style SendResp fill:#e8f5e9,stroke:#2e7d32


