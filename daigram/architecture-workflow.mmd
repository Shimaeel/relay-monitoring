%% ╔═══════════════════════════════════════════════════════════════════════╗
%% ║  DIAGRAM I — DATA TRANSFORMATION PIPELINE (RELAY → UI)              ║
%% ╚═══════════════════════════════════════════════════════════════════════╝
%%
%%  Linear data flow showing every transformation from raw Telnet
%%  bytes to rendered HTML in the browser.
%%
%% ═══════════════════════════════════════════════════════════════════════════

flowchart LR
    D1["Relay Device<br/>Telnet TCP:23"] -->|"raw text bytes"| D2["TelnetClient<br/>SendCmdReceiveData"]
    D2 -->|"string response"| D3["RawDataRingBuffer<br/>push(cmd, response)"]
    D3 -->|"waitPop"| D4["parseSERResponse<br/>regex line parser"]
    D4 -->|"vector of SERRecord<br/>(relay, date, time,<br/>element, status)"| D5["Stamp relay_id<br/>+ relay_name"]

    D5 --> D6

    subgraph D6["Three Parallel Outputs"]
      direction TB

      D6a["SQLite INSERT OR IGNORE<br/>→ ser_records.db<br/>(persistent storage)"]

      D6b["encodeSerRecordsToTlv<br/>ASN.1 BER/TLV binary<br/>Tags: 0x61 SET,<br/>0x30 SEQ,<br/>0x80 date, 0x81 time,<br/>0x82 element, 0x83 status,<br/>0x84 relay_id, 0x85 relay_name"]

      D6c["SharedRingBuffer<br/>IPC write(TLV)<br/>(new records only)"]
    end

    D6b -->|"WS binary frame<br/>:8765"| D7["Browser JS<br/>decodeSerRecordsFromTlv<br/>(sections.js)"]
    D7 -->|"JS objects array"| D8["Tabulator.setData<br/>rendered HTML table<br/>(relay.html)"]

    D6b -->|"WS binary frame<br/>:8765"| D7b["Browser JS<br/>_cserDecodeTlv<br/>(combine_ser.js)"]
    D7b -->|"merged records"| D8b["Combined Tabulator<br/>(index.html dashboard)"]

    D6c -->|"waitRead"| D9["SharedSerReader<br/>decodeSerRecordsFromTlv<br/>recordsToJsonTable"]
    D9 -->|"JSON string"| D10["ui/data.json<br/>(file on disk)"]
    D10 -->|"HTTP :8080<br/>or file://"| D11["Legacy UI<br/>Tabulator.setData<br/>(ui/index.html)"]

    D6a -->|"SQL via :8766"| D12["WSDBServer<br/>dbGetAll / dbQuery"]
    D12 -->|"JSON response"| D13["db_client.js<br/>DatabaseClient<br/>(Promise API)"]

    style D1 fill:#fce4ec,stroke:#e91e63
