%% ╔═══════════════════════════════════════════════════════════════════════╗
%% ║  DIAGRAM 1 — CLASS DIAGRAM                                          ║
%% ║  Source: architecture-classes.mmd                                    ║
%% ╚═══════════════════════════════════════════════════════════════════════╝

classDiagram
    direction TB

    %% ═════════════ APPLICATION FACADE ═════════════

    class TelnetSmlApp {
        -unique_ptr~Impl~ impl_
        +TelnetSmlApp()
        +~TelnetSmlApp()
        +start() bool
        +waitForExit() void
        +stop() void
        +isRunning() bool
    }

    class Impl {
        +atomic~bool~ app_running
        +TelnetClient client
        +ConnectionConfig conn
        +LoginConfig creds
        +RetryState retry
        +SERDatabase serDb
        +SERWebSocketServer wsServer
        +unique_ptr~WSDBServer~ dbApiServer
        +ThreadManager threadMgr
        +RawDataRingBuffer rawBuffer
        +SharedRingBuffer shmRing
        +unique_ptr~ReceptionWorker~ receptionWorker
        +unique_ptr~ProcessingWorker~ processingWorker
        +RelayService relayService
        +TimeSyncManager timeSyncMgr
        +PasswordManager passwordMgr
        +SharedSerReader shmReader
        +bool running
        +start() bool
        +waitForExit() void
        +stop() void
    }

    TelnetSmlApp *-- Impl : PIMPL

    %% ═════════════ THREAD 1: RECEPTION ═════════════

    class ReceptionWorker {
        -atomic~bool~ stop_flag_
        -thread worker_thread_
        -mutex queue_mutex_
        -condition_variable queue_cv_
        -deque~string~ command_queue_
        -TelnetClient& client_
        -ConnectionConfig& conn_
        -LoginConfig& creds_
        -RawDataRingBuffer& rawBuffer_
        -atomic~bool~& app_running_
        -bool connected_
        -bool logged_in_
        -ensureConnected() bool
        -executeCommand(cmd: string) void
        -runLoop() void
        +start() void
        +stop() void
        +queueCommand(cmd: string) void
        +resetConnection() void
    }

    class TelnetClient {
        -io_context
        -tcp_socket socket_
        -bool connected_
        -bool last_io_ok_
        -string last_response_
        -ms io_timeout_
        +TelnetClient()
        +connectCheck(host, port, timeout) bool
        +isConnected() bool
        +SendCmdReceiveData(cmd, buffer) bool
        +LoginLevel1Function(user, pass) bool
        +getLastResponse() string
        +getLastIoResult() bool
        +clearLastResponse() void
        -isResponseComplete(buf) bool
        -endsWithPrompt(buf) bool
    }

    ReceptionWorker --> TelnetClient : uses
    ReceptionWorker --> RawDataRingBuffer : push()

    %% ═════════════ BUFFERS ═════════════

    class RawDataMessage {
        +string command
        +string response
    }

    class RawDataRingBuffer {
        +static kMaxReaders: uint32 = 8
        +static kInvalidReader: uint32
        -size_t max_size_
        -mutex mutex_
        -condition_variable cv_
        -deque~RawDataMessage~ queue_
        -uint64_t base_index_
        -ReaderSlot readers_[kMaxReaders]
        +registerReader() ReaderId
        +unregisterReader(id) void
        +push(msg: RawDataMessage) bool
        +waitPop(id, stop) optional~RawDataMessage~
        +size() size_t
        +notifyAll() void
    }

    class SharedRingBuffer {
        +static kMaxReaders: uint32 = 8
        +static kInvalidReader: uint32
        -string name_
        -shared_memory_object shm_
        -mapped_region region_
        -Header* header_
        +SharedRingBuffer(name, capacity, mode)
        +~SharedRingBuffer()
        +static remove(name) bool
        +registerReader() ReaderId
        +unregisterReader(id) void
        +write(data, len) bool
        +waitRead(id, out, stop) bool
        +capacity() size_t
        +notifyAll() void
    }

    RawDataRingBuffer o-- RawDataMessage : stores

    %% ═════════════ THREAD 2: PROCESSING ═════════════

    class ProcessingWorker {
        -atomic~bool~ stop_flag_
        -thread worker_thread_
        -RawDataRingBuffer& rawBuffer_
        -SERDatabase& db_
        -SERWebSocketServer& wsServer_
        -SharedRingBuffer& shmRing_
        -atomic~bool~& app_running_
        -ReaderId readerId_
        -runLoop() void
        +start() void
        +stop() void
    }

    ProcessingWorker --> RawDataRingBuffer : waitPop()
    ProcessingWorker --> SERDatabase : insertAndGetNewRecords()
    ProcessingWorker --> SERWebSocketServer : broadcastAll()
    ProcessingWorker --> SharedRingBuffer : write()

    %% ═════════════ DATA LAYER ═════════════

    class SERRecord {
        +string record_id
        +string timestamp
        +string status
        +string description
        +SERRecord()
        +SERRecord(id, ts, status, desc)
    }

    class SERDatabase {
        -sqlite3* db_
        -string db_path_
        -string last_error_
        +SERDatabase(dbPath: string)
        +~SERDatabase()
        +open() bool
        +close() void
        +isOpen() bool
        +insertRecord(record) bool
        +insertRecords(records) int
        +insertAndGetNewRecords(records, inserted) vector~SERRecord~
        +getAllRecords() vector~SERRecord~
        +getRecordsByStatus(status) vector~SERRecord~
        +getRecordCount() int
        +exportToJSON(path) bool
        +getLastError() string
        +getDbHandle() sqlite3*
    }

    SERDatabase o-- SERRecord : stores

    %% ═════════════ PARSER & CODEC ═════════════

    class parseSERResponse {
        <<function>>
        +parseSERResponse(text: string) vector~SERRecord~
    }

    class asn_tlv {
        <<namespace>>
        +encodeSerRecordsToTlv(records) vector~uint8_t~
        +decodeSerRecordsFromTlv(data, size, records, error) bool
        +berAppendString(out, tag, value) void
        +readTlv(data, size, offset, info, error) bool
    }

    class TlvInfo {
        +uint8_t tag
        +size_t length
        +size_t valueStart
        +size_t totalLen
    }

    asn_tlv o-- TlvInfo

    %% ═════════════ THREAD 3: WEBSOCKET (SER) ═════════════

    class SERWebSocketServer {
        -SERDatabase& db_
        -unsigned short port_
        -io_context ioc_
        -thread server_thread_
        -shared_ptr~SessionManager~ sessionMgr_
        -function commandHandler_
        -function actionHandler_
        +SERWebSocketServer(db, port)
        +start() bool
        +stop() void
        +broadcastAll() void
        +broadcastText(text: string) void
        +setCommandHandler(cb) void
        +setActionHandler(cb) void
    }

    class SessionManager {
        -mutex mutex_
        -set~shared_ptr~WebSocketSession~~ sessions_
        +add(session) void
        +remove(session) void
        +forEach(fn) void
    }

    class WebSocketSession {
        -websocket_stream ws_
        -flat_buffer buffer_
        -SERDatabase& db_
        -shared_ptr~SessionManager~ sessMgr_
        +run() void
        +sendData() void
        +sendText(text) void
        -onRead(ec, bytes) void
    }

    SERWebSocketServer *-- SessionManager : owns
    SessionManager o-- WebSocketSession : manages N
    WebSocketSession --> SERDatabase : getAllRecords()
    SERWebSocketServer --> SERDatabase : queries

    %% ═════════════ THREAD 3b: DB API WS ═════════════

    class WSDBServer {
        -sqlite3* db_
        -unsigned short port_
        -io_context ioc_
        -thread server_thread_
        -mutex db_mutex_
        +WSDBServer(db, port)
        +start() bool
        +stop() void
    }

    class WSDBSession {
        -websocket_stream ws_
        -flat_buffer buffer_
        -sqlite3* db_
        -mutex& db_mutex_
        -SharedDBMemory* shm_
        +run() void
        -onRead(ec, bytes) void
    }

    class wsdb_ops {
        <<namespace>>
        +dbGetAll(id, db, mtx, table) string
        +dbGetIncremental(id, db, mtx, table, sinceRowId) string
        +dbQuery(id, db, mtx, sql, params) string
        +dbExec(id, db, mtx, sql, params) string
        +dbTables(id, db, mtx) string
        +dbSchema(id, db, mtx, table) string
        +dbDefine(id, db, mtx, table, columns) string
    }

    WSDBServer *-- WSDBSession : creates per client
    WSDBSession --> wsdb_ops : dispatches
    wsdb_ops --> SERDatabase : SQL via sqlite3*

    %% ═════════════ THREAD 4: POLLER ═════════════

    class ThreadManager {
        -SERDatabase& db_
        -chrono_seconds interval_
        -atomic~bool~ stop_flag_
        -thread poll_thread_
        -function pollingCallback_
        +ThreadManager(db, interval)
        +startAll() void
        +stopAll() void
        +setPollingCallback(fn) void
    }

    ThreadManager --> ReceptionWorker : queueCommand via callback

    %% ═════════════ THREAD 5: SHM READER ═════════════

    class SharedSerReader {
        -SharedRingBuffer& ring_
        -string output_path_
        -atomic~bool~ stop_flag_
        -thread worker_thread_
        -ReaderId readerId_
        -runLoop() void
        +SharedSerReader(ring, output_path)
        +start() void
        +stop() void
    }

    SharedSerReader --> SharedRingBuffer : waitRead()
    SharedSerReader --> asn_tlv : decodeSerRecordsFromTlv()

    %% ═════════════ SERVICE MANAGERS ═════════════

    class RelayService {
        -TelnetClient& client_
        -mutex mutex_
        +RelayService(client)
        +readRelayTime() DateResult
        +writeRelayTime(datetime) DateResult
    }

    class DateResult {
        +bool success
        +string datetime
        +string error
    }

    RelayService o-- DateResult
    RelayService --> TelnetClient : locked I/O

    class TimeSyncManager {
        -RelayService& relay_
        +TimeSyncManager(relay)
        +handleAction(action: string) string
        +static getLocalPCTime() string
        +compareTime(relay_dt, pc_dt) double
    }

    TimeSyncManager --> RelayService : readRelayTime / writeRelayTime

    class PasswordManager {
        -RelayService& relay_
        +PasswordManager(relay)
        +handleAction(jsonMsg: string) string
        +validatePassword(level, value) bool
        +changePassword(level, value) string
    }

    PasswordManager --> RelayService : changePassword

    %% ═════════════ ASN.1 DATE / PASSWORD HELPERS ═════════════

    class asn_date {
        <<namespace>>
        +encodeASN1Date(datetime) vector~uint8_t~
        +decodeASN1Date(data, size, datetime, error) bool
    }

    class asn_password {
        <<namespace>>
        +encodeASN1Password(password) vector~uint8_t~
        +decodeASN1Password(data, size, password, error) bool
    }

    RelayService ..> asn_date : uses
    PasswordManager ..> asn_password : uses

    %% ═════════════ CONFIG STRUCTS ═════════════

    class ConnectionConfig {
        +string host
        +int port
        +milliseconds timeout
    }

    class LoginConfig {
        +string l1_user
        +string l1_pass
    }

    class RetryState {
        +int max_retries
        +int current_attempt
        +seconds retry_delay
        +shouldRetry() bool
        +reset() void
    }

    %% ═════════════ JSON WRITER HELPERS ═════════════

    class ser_json_writer {
        <<functions>>
        +escapeJson(value) string
        +recordsToJsonTable(records) string
        +writeJsonToFile(path, json, error) bool
    }

    SharedSerReader --> ser_json_writer : recordsToJsonTable + writeJsonToFile

    %% ═════════════ FSM (Boost.SML) ═════════════

    class TelnetFSM {
        <<Boost.SML state machine>>
        States: Idle, Connecting, Login_L1,
                WaitingRetry, Operational,
                Polling, Done, Error
        Events: start_event, step_event,
                unhandled_event
        Guards: ConnectOk, LoginComplete,
                CanRetry, MaxRetries, SerComplete
        Actions: ConnectAction, Login1Action,
                 RetryWaitAction, PollSerAction,
                 ResetRetryAction
    }

    TelnetFSM --> TelnetClient : actions use
    TelnetFSM --> SERDatabase : PollSerAction stores

    %% ═════════════ UTILITY CLASSES ═════════════

    class ThreadSafeQueue~T~ {
        -queue~T~ queue_
        -mutex mutex_
        -condition_variable cv_
        +push(item: T) void
        +pop(item: T, stop_flag) bool
        +empty() bool
        +size() size_t
        +notify_all() void
    }

    class DatabaseWriter {
        -ThreadSafeQueue~vector~SERRecord~~ queue_
        -SERDatabase& db_
        -atomic~bool~ stop_flag_
        -thread writer_thread_
        +start() void
        +stop() void
        +enqueue(records) void
    }

    DatabaseWriter --> ThreadSafeQueue : uses
    DatabaseWriter --> SERDatabase : insertRecords

    %% ═════════════ IMPL OWNERSHIP ═════════════

    Impl *-- TelnetClient
    Impl *-- ConnectionConfig
    Impl *-- LoginConfig
    Impl *-- RetryState
    Impl *-- SERDatabase
    Impl *-- SERWebSocketServer
    Impl *-- WSDBServer
    Impl *-- ThreadManager
    Impl *-- RawDataRingBuffer
    Impl *-- SharedRingBuffer
    Impl *-- ReceptionWorker
    Impl *-- ProcessingWorker
    Impl *-- RelayService
    Impl *-- TimeSyncManager
    Impl *-- PasswordManager
    Impl *-- SharedSerReader


