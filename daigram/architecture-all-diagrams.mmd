%% ╔═══════════════════════════════════════════════════════════════════════╗
%% ║  DIAGRAM 5A — APPLICATION STARTUP & SHUTDOWN WORKFLOW                ║
%% ║  Source: architecture-workflow.mmd                                   ║
%% ╚═══════════════════════════════════════════════════════════════════════╝

flowchart TD
    Start([main.cpp Entry Point]) --> CreateApp[Create TelnetSmlApp]
    CreateApp --> CreateImpl[Create Impl via PIMPL]
    CreateImpl --> CallStart[app.start]

    CallStart --> OpenDB{Open SQLite DB}
    OpenDB -->|Fail| ReturnFalse([return false])
    OpenDB -->|OK| ExportJSON[Export existing records<br/>to ui/data.json]

    ExportJSON --> CreateRelayMgr[Create RelayManager<br/>with 3 relay configs]
    CreateRelayMgr --> SetHandlers[Set WS Handlers]

    subgraph SetHandlers[Configure WebSocket Handlers]
        direction TB
        CmdH[setCommandHandler<br/>relay_id:command routing]
        StreamH[setStreamCommandHandler<br/>FETCH_ALL_TAR support]
        ActH[setActionHandler<br/>start_relay / stop_relay<br/>relay_status / read_time<br/>sync_time / change_password]
    end

    SetHandlers --> StartWS{Start SERWebSocketServer<br/>port 8765}
    StartWS -->|Fail| CloseDB1[Close DB] --> ReturnFalse
    StartWS -->|OK| StartWSDB[Start WSDBServer<br/>port 8766]
    StartWSDB -->|Fail| WarnLog[Log warning<br/>non-fatal]
    StartWSDB -->|OK| SetPoll[Set Polling Callback<br/>queue SER to all active relays]
    WarnLog --> SetPoll

    SetPoll --> StartSHM[Start SharedSerReader<br/>Thread 5 spawned]
    StartSHM --> StartTM[Start ThreadManager<br/>SERPoller 120s + DatabaseWriter<br/>Thread 4 spawned]
    StartTM --> Running([Application Running<br/>Waiting for browser start_relay])

    Running --> WaitExit[waitForExit<br/>blocks on cin.get]
    WaitExit --> CallStop[app.stop]

    subgraph Shutdown[Shutdown Sequence]
        direction TB
        S1[app_running = false]
        S1 --> S2[relayMgr.stopAll<br/>stop all active pipelines]
        S2 --> S3[threadMgr.stopAll<br/>stop SERPoller + DatabaseWriter]
        S3 --> S4[shmReader.stop]
        S4 --> S5[dbApiServer.stop]
        S5 --> S6[wsServer.stop]
        S6 --> S7[serDb.close]
    end

    CallStop --> Shutdown
    Shutdown --> Exit([return 0])

    style Start fill:#e8f5e9,stroke:#2e7d32
    style ReturnFalse fill:#ffebee,stroke:#c62828
    style Running fill:#e3f2fd,stroke:#1565c0
    style Exit fill:#e8f5e9,stroke:#2e7d32
    style Shutdown fill:#fff3e0,stroke:#ef6c00


