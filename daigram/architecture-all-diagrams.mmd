%% ╔═══════════════════════════════════════════════════════════════════════╗
%% ║  DIAGRAM 5B — RELAY LIFECYCLE (ON-DEMAND START / STOP)               ║
%% ║  Source: architecture-workflow.mmd                                   ║
%% ╚═══════════════════════════════════════════════════════════════════════╝

flowchart TD
    BrowserStart([Browser sends<br/>action: start_relay<br/>relay_id: 1]) --> LockMtx[Lock RelayManager mutex]
    LockMtx --> AlreadyActive{Relay already<br/>active?}
    AlreadyActive -->|Yes| NoOp([No-op: already running])
    AlreadyActive -->|No| FindConfig{Find relay config<br/>by ID}
    FindConfig -->|Not found| ErrUnknown([Error: unknown relay])
    FindConfig -->|Found| CreatePipeline[Create RelayPipeline<br/>config + db + ws + shmRing]

    CreatePipeline --> StartPipeline[pipeline.start]

    subgraph PipelineStart[Pipeline Startup]
        direction TB
        P1[Create PipelineReceptionWorker<br/>with ConnectionFSM + CommandFSM]
        P1 --> P2[rxWorker.start<br/>spawn worker thread]
        P2 --> P3[Fire start_event<br/>FSM: Idle → Connecting]
        P3 --> P4[Create PipelineProcessingWorker]
        P4 --> P5[procWorker.start<br/>register ring reader + spawn thread]
        P5 --> P6[Queue initial SER command]
    end

    StartPipeline --> PipelineStart
    PipelineStart --> StoreActive[Store in active map]
    StoreActive --> RelayRunning([Relay Running<br/>Polling + Processing])

    %% Stop path
    BrowserStop([Browser sends<br/>action: stop_relay<br/>relay_id: 1]) --> LockMtx2[Lock RelayManager mutex]
    LockMtx2 --> FindActive{Relay in<br/>active map?}
    FindActive -->|No| ErrNotActive([Error: not active])
    FindActive -->|Yes| StopPipeline[pipeline.stop]

    subgraph PipelineStop[Pipeline Shutdown]
        direction TB
        X1[rxWorker.stop<br/>set stop_flag + notify CV]
        X1 --> X2[Join reception thread]
        X2 --> X3[procWorker.stop<br/>set stop_flag + notifyAll ring]
        X3 --> X4[Join processing thread]
    end

    StopPipeline --> PipelineStop
    PipelineStop --> EraseActive[Erase from active map]
    EraseActive --> RelayStopped([Relay Stopped])

    %% Status query
    BrowserStatus([Browser sends<br/>action: relay_status]) --> GetIds[Get active relay IDs]
    GetIds --> ReturnStatus([Return JSON<br/>active: 1, 3])

    style BrowserStart fill:#e3f2fd,stroke:#1565c0
    style BrowserStop fill:#fff3e0,stroke:#ef6c00
    style BrowserStatus fill:#f3e5f5,stroke:#7b1fa2
    style RelayRunning fill:#e8f5e9,stroke:#2e7d32
    style RelayStopped fill:#eceff1,stroke:#546e7a
    style NoOp fill:#eceff1,stroke:#546e7a
    style ErrUnknown fill:#ffebee,stroke:#c62828
    style ErrNotActive fill:#ffebee,stroke:#c62828


