%% ╔═══════════════════════════════════════════════════════════════════════╗
%% ║  DIAGRAM 5D — BROWSER REQUEST DISPATCH (WEBSOCKET ON_READ)           ║
%% ║  Source: architecture-workflow.mmd                                   ║
%% ╚═══════════════════════════════════════════════════════════════════════╝

flowchart TD
    Msg([WebSocket message<br/>received from browser]) --> Closed{Connection<br/>closed / error?}
    Closed -->|Yes| Deregister[Deregister from<br/>SessionManager]
    Deregister --> End1([Session ended])

    Closed -->|No| ParseMsg[Parse message string]
    ParseMsg --> IsRefresh{msg = refresh<br/>or getData?}

    IsRefresh -->|Yes| SendData[sendData<br/>query all DB records<br/>encode ASN.1 TLV<br/>send binary frame]
    SendData --> DoRead1([do_read — wait next])

    IsRefresh -->|No| IsJSON{Is JSON action?<br/>starts with curly brace<br/>and has action key}

    IsJSON -->|Yes| ExtractAction[Extract action value]
    ExtractAction --> MaskPwd{action =<br/>change_password?}
    MaskPwd -->|Yes| MaskLog[Mask payload in log]
    MaskPwd -->|No| FullLog[Log full message]
    MaskLog --> SpawnAction
    FullLog --> SpawnAction

    SpawnAction[Spawn detached thread] --> RouteAction

    subgraph RouteAction[Action Dispatch]
        direction TB
        A1{action?}
        A1 -->|start_relay| StartRelay[RelayManager<br/>startRelay relay_id]
        A1 -->|stop_relay| StopRelay[RelayManager<br/>stopRelay relay_id]
        A1 -->|relay_status| RelayStatus[Return active IDs]
        A1 -->|read_time| ReadTime[TimeSyncManager<br/>handleReadTime]
        A1 -->|sync_time| SyncTime[TimeSyncManager<br/>handleSyncTime]
        A1 -->|change_password| ChgPwd[PasswordManager<br/>handleAction]
    end

    RouteAction --> PostBack[Post JSON response<br/>back to WS strand]
    PostBack --> DoRead2([do_read — wait next])

    IsJSON -->|No| HasHandler{Has stream or<br/>cmd handler?}
    HasHandler -->|No| IgnoreMsg([Ignore — do_read])

    HasHandler -->|Yes| ParsePrefix[Parse relay_id:command<br/>prefix format]
    ParsePrefix --> SpawnCmd[Spawn detached thread]

    SpawnCmd --> TryStream{StreamCommandHandler<br/>available?}
    TryStream -->|Yes| IsFetchAll{Command =<br/>FETCH_ALL_TAR?}

    IsFetchAll -->|Yes| StreamLoop

    subgraph StreamLoop[FETCH_ALL_TAR Streaming]
        direction TB
        SL1[Loop: TAR 0, TAR 1, ...]
        SL1 --> SL2[handleUserCommand<br/>relay_id, TAR i]
        SL2 --> SL3{Response empty<br/>or Invalid Target?}
        SL3 -->|Yes| SL4[Send TAR_STREAM_END:count]
        SL3 -->|No| SL5[Send TAR_STREAM:i + response]
        SL5 --> SL6{abort flag?}
        SL6 -->|No| SL1
        SL6 -->|Yes| SL4
    end

    StreamLoop --> DoRead3([do_read — wait next])

    IsFetchAll -->|No| FallThrough[Not handled as stream]
    TryStream -->|No| FallThrough

    FallThrough --> SingleCmd[cmdHandler<br/>handleUserCommand<br/>synchronous response]
    SingleCmd --> HasResp{Response<br/>non-empty?}
    HasResp -->|Yes| SendText[sendTextResponse<br/>text WS frame]
    HasResp -->|No| SkipSend[Skip empty response]
    SendText --> DoRead4([do_read — wait next])
    SkipSend --> DoRead4

    style Msg fill:#e3f2fd,stroke:#1565c0
    style End1 fill:#eceff1,stroke:#546e7a
    style IgnoreMsg fill:#eceff1,stroke:#546e7a
    style DoRead1 fill:#e8f5e9,stroke:#2e7d32
    style DoRead2 fill:#e8f5e9,stroke:#2e7d32
    style DoRead3 fill:#e8f5e9,stroke:#2e7d32
    style DoRead4 fill:#e8f5e9,stroke:#2e7d32
    style RouteAction fill:#f3e5f5,stroke:#7b1fa2
    style StreamLoop fill:#fff3e0,stroke:#ef6c00


