%% ╔═══════════════════════════════════════════════════════════════════════╗
%% ║  DIAGRAM 5H — FULL SYSTEM: RELAY → C++ BACKEND → BROWSER UI         ║
%% ║  Source: architecture-workflow.mmd                                   ║
%% ╚═══════════════════════════════════════════════════════════════════════╝

flowchart TB

  %% ═══════════════════════════════════════════════════════════════════════
  %%  LAYER 1 — PHYSICAL RELAY DEVICES (Substation)
  %% ═══════════════════════════════════════════════════════════════════════

  subgraph Relays["Substation — Physical Relay Devices"]
    direction LR
    R1["SEL-751<br/>192.168.0.2:23<br/>Bay 1"]
    R2["SEL-421<br/>192.168.1.11:23<br/>Bay 2"]
    R3["SEL-451<br/>192.168.0.3:23<br/>Bay 3"]
  end

  %% ═══════════════════════════════════════════════════════════════════════
  %%  LAYER 2 — C++ BACKEND (telnet_sml_app)
  %% ═══════════════════════════════════════════════════════════════════════

  subgraph Backend["C++ Backend — TelnetSmlApp::Impl"]
    direction TB

    %% ── Application Controller ────────────────────────────────────────
    subgraph Controller["Application Controller"]
      direction LR
      MainEntry["main.cpp"]
      AppFacade["TelnetSmlApp<br/>(PIMPL Facade)"]
      Impl["Impl<br/>(Orchestrator)<br/>Owns every component"]
      MainEntry -->|creates| AppFacade
      AppFacade -->|unique_ptr| Impl
    end

    %% ── Relay Manager + On-Demand Pipelines ──────────────────────────
    subgraph RelayMgr["RelayManager — On-Demand Multi-Relay"]
      direction TB
      RM["RelayManager<br/>startRelay / stopRelay<br/>handleUserCommand<br/>queueCommand<br/>getActiveRelayIds"]

      subgraph Pipeline1["RelayPipeline — Relay 1"]
        direction LR

        subgraph RxW1["Thread 1A — ReceptionWorker"]
          direction TB
          ConnFSM1["ConnectionFSM<br/>Idle → Connecting → Login<br/>→ Operational"]
          CmdFSM1["CommandFSM<br/>SER · TAR · EVE · SET<br/>CTRL+C · CTRL+D"]
          TC1["TelnetClient<br/>connectCheck · Login<br/>SendCmdReceiveData"]
          ConnFSM1 --> TC1
          CmdFSM1 --> TC1
        end

        Ring1[/"RawDataRingBuffer<br/>(MPMC, 100 slots)<br/>push · waitPop"/]

        subgraph ProcW1["Thread 2A — ProcessingWorker"]
          direction TB
          Parse1["parseSERResponse<br/>text → SERRecord[]"]
          Stamp1["Stamp relay_id<br/>+ relay_name"]
          Parse1 --> Stamp1
        end

        RxW1 -->|"push(cmd, response)"| Ring1
        Ring1 -->|"waitPop (blocking)"| ProcW1
      end

      subgraph Pipeline23["RelayPipeline — Relay 2, 3<br/>(same structure per relay)"]
        direction LR
        RxWN["ReceptionWorker<br/>ConnectionFSM + CommandFSM<br/>+ TelnetClient"]
        RingN[/"RawDataRingBuffer"/]
        ProcWN["ProcessingWorker<br/>parse + stamp"]
        RxWN --> RingN --> ProcWN
      end

      RM -->|"creates on start_relay"| Pipeline1
      RM -->|"creates on start_relay"| Pipeline23
    end

    %% ── Data Layer ──────────────────────────────────────────────────
    subgraph DataLayer["Data Layer"]
      direction LR
      DB[("SERDatabase<br/>(SQLite ser_records.db)<br/>insertAndGetNewRecords<br/>getAllRecords<br/>relay_id per record")]
      ASN["asn_tlv namespace<br/>encodeSerRecordsToTlv<br/>decodeSerRecordsFromTlv<br/>Tags: 0x61, 0x30, 0x80–0x85"]
    end

    %% ── Service Managers ────────────────────────────────────────────
    subgraph Services["Service Managers"]
      direction LR
      TimeMgr["TimeSyncManager<br/>handleReadTime → DATE cmd<br/>handleSyncTime → SETTIME cmd<br/>ASN.1 Tag 33 decode<br/>compare relay ↔ PC time"]
      PwdMgr["PasswordManager<br/>handleAction<br/>PAS LEVEL1/2 cmd<br/>ASN.1 Tag 34 encode<br/>validate: TAIL1 / OTTER1"]
      RelaySvc["RelayService<br/>thread-safe wrapper<br/>readRelayTime<br/>sendRelayCommand"]
      TimeMgr --> RelaySvc
      PwdMgr --> RelaySvc
    end

    %% ── Global Threads ──────────────────────────────────────────────
    subgraph GlobalThreads["Global Threads"]
      direction LR
      SERPoller["Thread 4 — SERPoller<br/>every 120s<br/>queue SER to all<br/>active relays"]
      SHMReader["Thread 5 — SharedSerReader<br/>waitRead → decode TLV<br/>→ recordsToJsonTable<br/>→ writeJsonToFile"]
    end

    %% ── Servers ─────────────────────────────────────────────────────
    subgraph Servers["WebSocket Servers"]
      direction LR

      subgraph WS8765["Thread 3 — SERWebSocketServer :8765"]
        direction TB
        WSServer["SERWebSocketServer<br/>start · stop<br/>broadcastAll · broadcastText"]
        SessMgr["SessionManager<br/>add · remove · getSessions"]
        WSSess["WebSocketSession × N<br/>sendData (binary TLV)<br/>sendTextResponse<br/>on_read dispatch:<br/>  refresh · JSON action<br/>  streaming · command"]
        WSServer --> SessMgr --> WSSess
      end

      subgraph WS8766["Thread 3b — WSDBServer :8766"]
        direction TB
        DBServer["WSDBServer<br/>start · stop"]
        DBSess["WSDBSession<br/>handleRequest dispatch"]
        DBOps["wsdb_ops::<br/>dbGetAll · dbGetIncremental<br/>dbQuery · dbExec<br/>dbTables · dbSchema · dbDefine"]
        DBServer --> DBSess --> DBOps
      end
    end

    %% ── Shared Memory ───────────────────────────────────────────────
    SHMRing[/"SharedRingBuffer<br/>(IPC MPMC, 500 KB)<br/>write · waitRead<br/>up to 8 readers"/]
    SHMBlock[/"SharedDBMemory<br/>(latest-state block)<br/>DB change notifications"/]
    DataJSON["ui/data.json<br/>(auto-generated)"]
  end

  %% ═══════════════════════════════════════════════════════════════════════
  %%  LAYER 3 — TRANSPORT (HTTP + WebSocket + IPC)
  %% ═══════════════════════════════════════════════════════════════════════

  subgraph Transport["Transport Layer"]
    direction LR
    HTTP["serve.ps1<br/>HTTP :8080<br/>Static files<br/>(HTML / JS / CSS)<br/>COOP + COEP headers"]
    WSBIN["ws://localhost:8765<br/>↓ Binary: ASN.1 BER/TLV<br/>↓ Text: relay responses<br/>↑ Commands: relay_id:cmd<br/>↑ JSON actions: start/stop<br/>  relay, time, password"]
    WSJSON["ws://localhost:8766<br/>↕ JSON CRUD<br/>getAll · getIncremental<br/>query · exec · tables<br/>schema · define"]
  end

  %% ═══════════════════════════════════════════════════════════════════════
  %%  LAYER 4 — BROWSER UI
  %% ═══════════════════════════════════════════════════════════════════════

  subgraph BrowserUI["Browser UI"]
    direction TB

    subgraph RelayApp["relay-app/ — Primary UI"]
      direction TB
      Dashboard["index.html<br/>Dashboard<br/>Relay card grid<br/>Combined SER table<br/>(all relays merged)"]
      RelayDetail["relay.html?id=N<br/>Per-Relay Detail View"]

      subgraph Sections["relay.html Sections"]
        direction LR
        SecSER["SER Events<br/>Tabulator table<br/>ASN.1 TLV decode"]
        SecTAR["TAR Reports<br/>FETCH_ALL_TAR<br/>streaming display"]
        SecRW["Relay Words<br/>SHOSET command<br/>Tabulator table"]
        SecIO["I/O Points<br/>Tabulator table"]
        SecTime["Time Sync<br/>read_time / sync_time<br/>relay ↔ PC comparison"]
        SecPwd["Password Change<br/>LEVEL1 / LEVEL2<br/>validation UI"]
        SecCTR["COMTRADE<br/>CTR C/D commands<br/>file download"]
      end

      RelayDetail --> Sections
    end

    subgraph RelayAppJS["JavaScript Layer"]
      direction LR
      DataJS["data.js<br/>Relay configs<br/>getRelays()"]
      DashJS["dashboard.js<br/>Card rendering<br/>status badges"]
      SectionsJS["sections.js<br/>ASN.1 TLV decoder<br/>WS connect per section<br/>Tabulator init + update<br/>Command send/receive"]
      CombineJS["combine_ser.js<br/>Multi-relay aggregation<br/>_cserDecodeTlv()<br/>Combined Tabulator"]
      RelayJS["relay.js<br/>URL param routing<br/>Section controller"]
    end

    subgraph LegacyUI["ui/ — Legacy / Alternative"]
      direction LR
      UIIndex["index.html<br/>Standalone SER viewer"]
      UIHTML["ui.html<br/>Sidebar-nav dashboard"]
      UIStatus["status.html<br/>Status panel grid"]
      UICmd["command.html<br/>Direct command input"]
      SHMWorker["shm_worker.js<br/>Web Worker<br/>WS → SharedArrayBuffer"]
    end

    subgraph DBAPI["websocket API/ — DB Client"]
      direction LR
      DBClient["db_client.js<br/>DatabaseClient class<br/>Promise-based API<br/>auto-reconnect"]
    end
  end

  %% ═══════════════════════════════════════════════════════════════════════
  %%  DATA FLOW EDGES
  %% ═══════════════════════════════════════════════════════════════════════

  %% Relay ↔ Backend (Telnet TCP:23)
  R1 <-->|"Telnet TCP:23<br/>SER · TAR · EVE · DATE<br/>PAS · SET · FIL DIR<br/>CTRL+C · CTRL+D"| TC1
  R2 <-->|"Telnet TCP:23"| RxWN
  R3 <-->|"Telnet TCP:23"| RxWN

  %% RelaySvc ↔ TelnetClient (for time sync, password)
  RelaySvc -->|"DATE / SETTIME / PAS<br/>via active relay client"| TC1

  %% Processing → Data Layer
  ProcW1 -->|"insertAndGetNewRecords"| DB
  ProcWN -->|"insertAndGetNewRecords"| DB
  ProcW1 -->|"encode TLV"| ASN
  ProcWN -->|"encode TLV"| ASN

  %% Processing → WS Broadcast
  ProcW1 -->|"broadcastAll<br/>(full DB as TLV)"| WSServer
  ProcWN -->|"broadcastAll"| WSServer
  ProcW1 -->|"broadcastText<br/>(non-SER responses)"| WSServer
  ProcWN -->|"broadcastText"| WSServer

  %% Processing → Shared Memory
  ProcW1 -->|"write TLV<br/>(new records only)"| SHMRing
  ProcWN -->|"write TLV"| SHMRing

  %% Shared Memory → JSON Writer
  SHMRing -->|"waitRead (blocking)"| SHMReader
  SHMReader -->|"decode + write"| DataJSON

  %% Poller → Relay Manager
  SERPoller -->|"queueCommand SER<br/>to each active relay"| RM

  %% DB API → Data Layer
  DBOps -->|"SQL via sqlite3*"| DB

  %% DB API → Shared Memory notification
  DBSess -->|"exec / define<br/>→ notify"| SHMBlock

  %% Impl ownership (dashed)
  Impl -.->|owns| RM
  Impl -.->|owns| DB
  Impl -.->|owns| WSServer
  Impl -.->|owns| DBServer
  Impl -.->|owns| SERPoller
  Impl -.->|owns| SHMReader
  Impl -.->|owns| SHMRing
  Impl -.->|owns| TimeMgr
  Impl -.->|owns| PwdMgr

  %% WS action routing
  WSSess -->|"action: start_relay<br/>stop_relay · relay_status"| RM
  WSSess -->|"action: read_time<br/>sync_time"| TimeMgr
  WSSess -->|"action: change_password"| PwdMgr
  WSSess -->|"relay command<br/>relay_id:cmd"| RM

  %% ── Backend ↔ Transport ───────────────────────────────────────────
  WSServer <-->|"ASN.1 BER/TLV binary<br/>+ text + JSON actions"| WSBIN
  DBServer <-->|"JSON CRUD"| WSJSON
  HTTP -->|"static files<br/>HTML · JS · CSS"| BrowserUI

  %% ── Transport ↔ Browser ───────────────────────────────────────────
  WSBIN <-->|"binary frames<br/>text frames"| SectionsJS
  WSBIN <-->|"binary frames"| CombineJS
  WSBIN <-->|"binary frames"| SHMWorker
  WSJSON <-->|"JSON frames"| DBClient

  %% ── Browser internal flows ────────────────────────────────────────
  DataJS -->|"relay configs"| DashJS
  DataJS -->|"relay configs"| CombineJS
  SectionsJS -->|"decoded records"| SecSER
  SectionsJS -->|"TAR responses"| SecTAR
  SectionsJS -->|"SHOSET parse"| SecRW
  SectionsJS -->|"I/O parse"| SecIO
  SectionsJS -->|"JSON response"| SecTime
  SectionsJS -->|"JSON response"| SecPwd
  SectionsJS -->|"CTR response"| SecCTR
  CombineJS -->|"merged records"| Dashboard

  %% ═══════════════════════════════════════════════════════════════════════
