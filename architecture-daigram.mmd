flowchart TB
  %% ===== C++ PROCESS ARCHITECTURE =====
  %% Relay Device -> TelnetClient Thread -> SPSC Ring Buffer -> FSM/Processing Thread -> SQLite -> WebSocket Server
  
  subgraph CPPProcess["C++ Process - Sequential Pipeline"]
    direction TB
    relay["🔌 Relay Device\n(Telnet Server)\nPort 23"]
    telnetThread["TelnetClient Thread\n(ReceptionWorker)"]
    spscRing["C++ SPSC Ring Buffer\n(RawDataRingBuffer)"]
    fsmThread["FSM / Processing Thread\n(ProcessingWorker)"]
    sqlite["SQLite\n(Persistent Storage)"]
    wsServer["WebSocket Server\n(After DB Write)"]
    
    relay -->|"TCP"| telnetThread
    telnetThread -->|"push"| spscRing
    spscRing -->|"waitPop"| fsmThread
    fsmThread -->|"insertRecords"| sqlite
    sqlite -->|"on success"| wsServer
  end

  subgraph External["External Systems"]
    relay2["🔌 Substation Relay\n(Telnet Server)\nPort 23"]
  end

  subgraph Reception["Reception Layer (TelnetClient Thread)"]
    direction TB
    client["TelnetClient\n(TCP/Telnet I/O)"]
    recvWorker["ReceptionWorker\n(Non-blocking)"]
    rawRing["RawDataRingBuffer\n(SPSC Queue)\n📦 command + response"]
    
    recvWorker -->|uses| client
    client -->|"push\n(immediate)"| rawRing
  end

  subgraph Processing["Processing Layer (Thread 2)"]
    direction TB
    procWorker["ProcessingWorker\n(Validation + Storage)"]
    parser["parseSERResponse()\n(Text → Records)"]
    codec["ASN.1 BER/TLV\nCodec"]
    
    procWorker -->|calls| parser
    procWorker -->|encodes| codec
  end

  subgraph Data["Data Layer"]
    db["💾 SERDatabase\n(SQLite)\nser_records.db"]
    shmRing["SharedRingBuffer\n(Lock-free)\n500KB"]
    json["📄 data.json\n(UI Export)"]
    shmReader["SharedSerReader\n(Thread 5)"]
    
    shmRing -->|waitRead| shmReader
    shmReader -->|writes| json
  end

  subgraph Server["WebSocket Server (Thread 3)"]
    direction TB
    ws["🌐 SERWebSocketServer\nPort 8765"]
    sessMgr["SessionManager\n(Client Registry)"]
    sessions["WebSocketSession[]\n(Per-client)"]
    http["serve.ps1\n(HTTP Server)\nPort 8080"]
    
    ws -->|owns| sessMgr
    sessMgr -->|manages| sessions
  end

  subgraph Browser["Browser - Sequential Pipeline"]
    direction TB
    wsClient["WebSocket Client\n(ws://localhost:8765)"]
    jsWorker["JS Worker\n(Optional)\nshm_worker.js"]
    mainJS["Main JS Thread\n(DOM Access)"]
    tabulator["Tabulator / JSON Export\n(index.html)"]
    
    wsClient -->|"onmessage"| jsWorker
    jsWorker -->|"postMessage"| mainJS
    mainJS -->|"render"| tabulator
  end

  subgraph Polling["Polling Layer (Thread 4)"]
    threadMgr["ThreadManager\n(2 min interval)"]
  end

  subgraph App["Application Controller"]
    main["main.cpp\n(Entry Point)"]
    app["TelnetSmlApp\n(Orchestrator)"]
    
    main -->|creates| app
  end

  %% ===== DATA FLOW (Reception Path) =====
  relay -->|"TCP Response\n(SER records)"| client
  client -->|"Telnet TCP:23\n(SER command)"| relay

  %% ===== DATA FLOW (Processing Path) =====
  rawRing -->|"waitPop\n(blocking)"| procWorker
  
  %% Processing outputs (SEQUENTIAL: DB first, then WebSocket)
  procWorker -->|"1️⃣ insertRecords()"| db
  db -->|"on success"| ws
  ws -.->|"2️⃣ broadcast()"| wsClient
  procWorker -->|"3️⃣ write()"| shmRing

  %% WebSocket push to browser
  ws -->|"🚀 PUSH\nASN.1 BER/TLV"| wsClient
  sessions -->|"on request"| db

  %% HTTP server
  http -->|"COOP/COEP\nheaders"| tabulator

  %% Polling triggers
  threadMgr -->|"queueCommand('SER')"| recvWorker
  app -->|starts| threadMgr
  app -->|starts| recvWorker
  app -->|starts| procWorker
  app -->|starts| ws

  %% ===== FSM States (Legacy/Reference) =====
  subgraph FSM["State Machine Flow (Legacy Mode)"]
    direction LR
    idle["Idle"] -->|start| connecting["Connecting"]
    connecting -->|ok| login["Login_L1"]
    connecting -->|fail| error["Error"]
    login -->|success| operational["Operational"]
    login -->|retry| waiting["WaitingRetry"]
    waiting -->|delay| connecting
    operational -->|poll| polling["Polling"]
    polling -->|done| done["Done"]
    polling -->|fail| error
  end

  %% ===== THREAD LEGEND =====
  subgraph Legend["Thread Architecture"]
    direction LR
    t1["🧵 Thread 1\nReception\n(Non-blocking I/O)"]
    t2["🧵 Thread 2\nProcessing\n(Parse + Store)"]
    t3["🧵 Thread 3\nWebSocket\n(Push Server)"]
    t4["🧵 Thread 4\nPoller\n(2 min interval)"]
    t5["🧵 Thread 5\nSHM Reader\n(JSON Writer)"]
    t6["🧵 Thread 6\nDB Writer\n(Async)"]
  end

  %% Styling
  classDef external fill:#ffebee,stroke:#c62828
  classDef reception fill:#e3f2fd,stroke:#1565c0
  classDef processing fill:#e8f5e9,stroke:#2e7d32
  classDef data fill:#fff3e0,stroke:#ef6c00
  classDef server fill:#f3e5f5,stroke:#7b1fa2
  classDef browser fill:#e0f7fa,stroke:#00838f
  classDef app fill:#fce4ec,stroke:#ad1457

  class relay external
  class client,recvWorker,rawRing reception
  class procWorker,parser,codec processing
  class db,shmRing,json,shmReader data
  class ws,sessMgr,sessions,http server
  class wsClient,jsWorker,mainJS,tabulator browser
  class main,app,threadMgr app
